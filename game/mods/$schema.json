{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ModModel",
  "oneOf": [
    {
      "type": "object",
      "properties": {
        "spaceship": {
          "$ref": "#/$defs/Entry%3CSpaceshipModel%3E"
        }
      },
      "additionalProperties": false,
      "required": [
        "spaceship"
      ]
    },
    {
      "type": "object",
      "properties": {
        "device": {
          "$ref": "#/$defs/Entry%3CDeviceModel%3E"
        }
      },
      "additionalProperties": false,
      "required": [
        "device"
      ]
    },
    {
      "type": "object",
      "properties": {
        "unit_definition": {
          "$ref": "#/$defs/Entry%3CUnitDefinitionModel%3E"
        }
      },
      "additionalProperties": false,
      "required": [
        "unit_definition"
      ]
    },
    {
      "type": "object",
      "properties": {
        "unit_variable": {
          "$ref": "#/$defs/Entry%3CUnitVariableModel%3E"
        }
      },
      "additionalProperties": false,
      "required": [
        "unit_variable"
      ]
    },
    {
      "type": "object",
      "properties": {
        "game_setting": {
          "$ref": "#/$defs/GameSettings"
        }
      },
      "additionalProperties": false,
      "required": [
        "game_setting"
      ]
    }
  ],
  "$defs": {
    "ActivationMode": {
      "type": "string",
      "enum": [
        "Automatic",
        "Manual"
      ]
    },
    "ColorDataSerialized": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "array",
          "items": {
            "type": "number",
            "format": "float"
          },
          "maxItems": 4,
          "minItems": 4
        },
        {
          "type": "object",
          "properties": {
            "a": {
              "type": "number",
              "format": "float"
            },
            "b": {
              "type": "number",
              "format": "float"
            },
            "g": {
              "type": "number",
              "format": "float"
            },
            "r": {
              "type": "number",
              "format": "float"
            }
          },
          "required": [
            "r",
            "g",
            "b",
            "a"
          ]
        }
      ]
    },
    "ColorModel": {
      "$ref": "#/$defs/ColorDataSerialized"
    },
    "DeviceModelId": {
      "type": "string",
      "pattern": "^[0-9a-z_]+:[0-9a-z_/]+(\\.[0-9a-z_]+)?$"
    },
    "Entry<DeviceModel>": {
      "type": "object",
      "properties": {
        "activation": {
          "$ref": "#/$defs/ActivationMode"
        },
        "id": {
          "type": "string",
          "pattern": "^[0-9a-z_]+:[0-9a-z_/]+$"
        }
      },
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "player_inputs": {
              "$ref": "#/$defs/PlayerInputsDeviceModel"
            }
          },
          "required": [
            "player_inputs"
          ]
        },
        {
          "type": "object",
          "properties": {
            "tank_controller": {
              "$ref": "#/$defs/TankControllerDeviceModel"
            }
          },
          "required": [
            "tank_controller"
          ]
        }
      ],
      "required": [
        "id",
        "activation"
      ]
    },
    "Entry<SpaceshipModel>": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[0-9a-z_]+:[0-9a-z_/]+$"
        },
        "model_size": {
          "type": "number",
          "format": "float"
        },
        "sprite": {
          "$ref": "#/$defs/HandleId"
        },
        "unit": {
          "$ref": "#/$defs/UnitDefinitionModelId"
        }
      },
      "required": [
        "id",
        "sprite",
        "model_size",
        "unit"
      ]
    },
    "Entry<UnitDefinitionModel>": {
      "type": "object",
      "properties": {
        "builtin_devices": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/DeviceModelId"
          }
        },
        "id": {
          "type": "string",
          "pattern": "^[0-9a-z_]+:[0-9a-z_/]+$"
        },
        "preset_variables": {
          "type": "object",
          "additionalProperties": false,
          "patternProperties": {
            "^[0-9a-z_]+:[0-9a-z_/]+(\\.[0-9a-z_]+)?$": {
              "type": "number",
              "format": "double"
            }
          }
        },
        "weight": {
          "$ref": "#/$defs/Formula"
        }
      },
      "required": [
        "id",
        "weight",
        "preset_variables",
        "builtin_devices"
      ]
    },
    "Entry<UnitVariableModel>": {
      "type": "object",
      "properties": {
        "default_value": {
          "description": "The default value of the variable",
          "type": "number",
          "format": "double"
        },
        "id": {
          "type": "string",
          "pattern": "^[0-9a-z_]+:[0-9a-z_/]+$"
        },
        "readonly": {
          "description": "Whether the variable is read-only (cannot be modified after being initialized)",
          "type": "boolean"
        }
      },
      "required": [
        "id",
        "default_value",
        "readonly"
      ]
    },
    "Formula": {
      "description": "fn() -> f64\nIds refer to unit variables by default",
      "anyOf": [
        {
          "description": "A formula string, e.g. \"2 * x + 1\"",
          "type": "string"
        },
        {
          "description": "A constant number, e.g. 3.14",
          "type": "number",
          "format": "double"
        }
      ]
    },
    "GameSettings": {
      "type": "object",
      "properties": {
        "draw_grid": {
          "type": "boolean"
        },
        "grid_color": {
          "$ref": "#/$defs/ColorModel"
        },
        "grid_scale": {
          "type": "number",
          "format": "float"
        },
        "zoom": {
          "type": "number",
          "format": "float"
        }
      },
      "additionalProperties": false,
      "required": [
        "zoom",
        "draw_grid",
        "grid_color",
        "grid_scale"
      ]
    },
    "HandleId": {
      "type": "string",
      "pattern": "^[0-9a-z_]+:[0-9a-z_/]+(\\.[0-9a-z_]+)?$"
    },
    "PlayerInputsDeviceModel": {
      "type": "object",
      "additionalProperties": false
    },
    "TankControllerDeviceModel": {
      "type": "object",
      "properties": {
        "acceleration_force": {
          "type": "number",
          "format": "float"
        },
        "braking_force": {
          "type": "number",
          "format": "float"
        },
        "max_angular_speed": {
          "type": "number",
          "format": "float"
        },
        "max_speed": {
          "type": "number",
          "format": "float"
        },
        "turn_torgue": {
          "type": "number",
          "format": "float"
        }
      },
      "additionalProperties": false,
      "required": [
        "acceleration_force",
        "braking_force",
        "turn_torgue",
        "max_speed",
        "max_angular_speed"
      ]
    },
    "UnitDefinitionModelId": {
      "type": "string",
      "pattern": "^[0-9a-z_]+:[0-9a-z_/]+(\\.[0-9a-z_]+)?$"
    }
  }
}